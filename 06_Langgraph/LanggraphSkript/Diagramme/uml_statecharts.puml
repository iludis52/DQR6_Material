@startuml Mealy-Getränkeautomat
left to right direction
title Mealy-Getränkeautomat

[*] --> hat0E

hat0E --> hat1E : 1E einwerfen / 'piep'
hat0E --> hat0E : abbrechen / 'piep'
hat1E --> hat0E : 1E einwerfen / Limo
hat1E --> hat0E : abbrechen / -1€

@enduml


