' ============================================================================
' Kapitel 8. Datenrucksack
' ============================================================================

@startuml
left to right direction
skinparam backgroundColor transparent
skinparam shadowing false
skinparam state {
  BackgroundColor #F5F5F5
  BorderColor #333333
}

title Konzept 3: Der Datenzustand als Rucksack

[*] --> klassifizieren
klassifizieren -right-> recherchieren
recherchieren --> ausgeben
ausgeben -right-> [*]

state klassifizieren {
  klassifizieren : liest: nachrichten
  klassifizieren : schreibt: route
}

state recherchieren {
  recherchieren : liest: nachrichten
  recherchieren : schreibt: ergebnis, route
}

state ausgeben {
  ausgeben : liest: ergebnis
}

note top of klassifizieren
  **Der Rucksack (State)**
  ━━━━━━━━━━━━━━━━━━━
  nachrichten: [msg1, msg2]
  route: ""
  ergebnis: ""
  fehler_zaehler: 0
  ─────────────────
  Jeder Knoten empfängt
  den gesamten Rucksack.
  Zurück kommt nur ein
  **partielles Update**:
  {"route": "recherche"}
end note
@enduml


' ============================================================================
' Kapitel 9. Zyklen
' ============================================================================

@startuml
left to right direction
skinparam backgroundColor transparent
skinparam shadowing false
skinparam state {
  BackgroundColor #F5F5F5
  BorderColor #333333
}

title Konzept 4: Zyklen — vom Workflow zum Agenten

[*] --> planen

planen -right-> tool_aufrufen
tool_aufrufen -right-> pruefen

state nach_pruefung <<choice>>
pruefen --> nach_pruefung : nach_pruefung(state)

nach_pruefung -right-> antworten : "fertig"
nach_pruefung -[#CC0000,bold]-> planen : "nochmal"

antworten -right-> [*]

note top of nach_pruefung
  **Abbruchbedingungen:**
  1. ergebnis_ok == True
  2. fehler_zaehler >= 3
  Ohne Abbruchbedingung
  → **Endlosschleife!**
end note

note top of planen
  <color:#CC0000>━━ Rückkante</color>
  Diese Kante macht
  aus dem Workflow
  einen **Agenten**.
end note
@enduml

