' ============================================================================
' 4. GETRÄNKEAUTOMAT (MOORE)
' ============================================================================
' Moore: Ausgabe hängt nur vom Zielzustand ab.
' MOORE_OUTPUTS wird als Transition-Action geschrieben,
' zeigt aber immer die Ausgabe des ZIELZUSTANDS.

@startuml Moore-Getränkeautomat
'left to right direction
title Getränkeautomat (Moore)

[*] -right-> hat0E

hat0E -right-> hat1E : 1E einwerfen /\nout="hat1E"
hat1E -right-> OK : 1E einwerfen /\nout="OK"
hat1E -down-> back : abbrechen /\nout="back"
OK -left-> hat0E : warten /\nout="hat0E"
back -left-> hat0E : warten /\nout="hat0E"

note bottom
  MOORE_OUTPUTS = {
    "hat0E": "2E",
    "hat1E": "1E",
    "OK":    "Limo",
    "back":  "-1E"
  }
end note

@enduml


