' ============================================================================
' Kapitel 5. EFSM
' ============================================================================

@startuml EFSM
left to right direction
skinparam backgroundColor transparent
skinparam shadowing false

title Vom DEA zum erweiterten Zustandsautomaten (EFSM)

state "Klassischer DEA" as dea {
  state "recherchieren" as d1
  state "antworten" as d2
  d1 --> d2 : eingabe
  note bottom of d1
    Zustand = nur der Knoten
    (""recherchieren"" oder ""antworten"")
  end note
}

state "Erweiterter Automat (EFSM)" as efsm {
  
  state "recherchieren" as e1
  e1 : ---
  e1 : zähler = 2
  e1 : ergebnis = "..."
  e1 : quellen = [web, db]
  
  state "antworten" as e2
  e2 : ---
  e2 : zähler = 2
  e2 : ergebnis = "finale Antwort"
  e2 : quellen = [web, db]

  e1 --> e2 : [zähler >= 3] / ergebnis aktualisieren
  e1 --> e1 : [zähler < 3] / zähler++

  note bottom of e1
    Zustand = Knoten + Daten
    δ(q, **D**) → (q', **D'**)
  end note
}

dea -[hidden]down-> efsm
@enduml


